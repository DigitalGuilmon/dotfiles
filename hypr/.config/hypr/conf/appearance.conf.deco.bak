# --- Apariencia (M4 Optimized) ---
general {
    gaps_in = 6
    gaps_out = 15
    border_size = 2
    col.active_border = rgb(c678dd) rgb(98c379) 45deg # Tu púrpura y verde
    col.inactive_border = rgba(282c34aa)
    layout = master
}

decoration {
    rounding = 12
    active_opacity = 1.0
    inactive_opacity = 0.8  # Reducido para mejor enfoque visual
    dim_inactive = true
    dim_strength = 0.2
    
    blur {
        enabled = true
        size = 8            # Incrementado de 6
        passes = 4          # Incrementado de 3 para suavidad
        new_optimizations = true
        xray = true
        noise = 0.01        # Añade textura al desenfoque
    }

    shadow {
        enabled = true
        range = 25
        render_power = 4
        color = rgba(c678dd44) # Sombra con tinte púrpura
    }
}

animations {
    enabled = yes
    # Curvas personalizadas para efecto orgánico
    bezier = overshot, 0.05, 0.9, 0.1, 1.1
    bezier = fluent_decel, 0, 0.2, 0.4, 1
    
    animation = windows, 1, 5, overshot, slide
    animation = border, 1, 5, default
    animation = borderangle, 1, 50, default, loop # Bordes rotando
    animation = fade, 1, 4, default
    animation = workspaces, 1, 5, overshot, slidevert
}

master {
    new_status = master
    mfact = 0.5
}

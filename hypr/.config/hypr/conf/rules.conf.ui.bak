# --- Reglas de Ventana ---
windowrulev2 = workspace 1, class:^(jetbrains-idea|Code|lean|coq)$
windowrulev2 = workspace 2, class:^(Brave-browser|firefox)$
windowrulev2 = workspace 4, class:^(DBeaver)$
windowrulev2 = workspace 5, class:^(Postman|Insomnia)$
windowrulev2 = workspace 5, title:^(Z3|SMT|Verification)$
windowrulev2 = workspace 6, class:^(discord|TelegramDesktop)$
windowrulev2 = workspace 7, class:^(Steam|Spotify)$
windowrulev2 = workspace 7, class:^(org.pwmt.zathura|evince)$
windowrulev2 = workspace 8, class:^(btop)$
windowrulev2 = workspace 9, class:^(VirtualBox Manager)$

# Flotación
windowrulev2 = float, class:^(pavucontrol|blueman-manager|nm-connection-editor)$
windowrulev2 = float, title:^(Confirmar|Archivos)$

# --- Reglas de Capa para Efectos de Cristal ---
layerrule = blur, waybar
layerrule = ignorezero, waybar
layerrule = blur, rofi
layerrule = ignorealpha 0.5, rofi
layerrule = blur, swaync-control-center
layerrule = blur, swaync-notification-window
layerrule = ignorezero, swaync-control-center
layerrule = ignorezero, swaync-notification-window

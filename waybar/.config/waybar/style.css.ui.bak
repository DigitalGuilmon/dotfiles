/* Definición de la animación de colores */
@keyframes rgb-border {
  0% {
    border-image-source: linear-gradient(45deg, #c678dd, #98c379);
  }
  50% {
    border-image-source: linear-gradient(45deg, #98c379, #82aaff);
  }
  100% {
    border-image-source: linear-gradient(45deg, #c678dd, #98c379);
  }
}

/* Estilo para los espacios de trabajo activos */
#workspaces button.active {
  background-color: rgba(49, 50, 68, 0.8);
  color: #cdd6f4;
  border: 2px solid;
  border-image-slice: 1;
  border-image-source: linear-gradient(45deg, #c678dd, #98c379);
  animation: rgb-border 3s linear infinite;
  border-radius: 10px;
}

/* Todos los módulos de información con RGB */
#cpu, 
#memory, 
#disk, 
#network, 
#language, 
#window, 
#clock, 
#tray, 
#custom-updates, 
#custom-cava {
  background-color: rgba(30, 30, 46, 0.8);
  color: #cdd6f4;
  padding: 0 10px;
  margin: 4px 4px;
  border: 2px solid;
  border-image-slice: 1;
  border-image-source: linear-gradient(45deg, #c678dd, #98c379);
  animation: rgb-border 3s linear infinite;
}
